              "host": ["{{base_url}}"],
              "path": ["accounts", "{{account_id}}", "campaigns", "{{campaign_id}}"]
            },
            "description": "Retorna campanha completa com:\n- adset_count, ad_count\n- adsets[]: id, name, status, effective_status\n  - ads[]: id, name, status, effective_status"
          }
