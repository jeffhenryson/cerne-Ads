          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/sync/{{account_id}}/insights/campaigns?campaign_id={{campaign_id}}&date_from=2026-01-01&date_to=2026-03-28&chunk_size_days=7",
              "host": ["{{base_url}}"],
