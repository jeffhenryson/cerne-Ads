    {
      "name": "Jobs",
      "description": "Gestão de SyncJobs. Use GET /{job_id} para polling de progresso.",
      "item": [
        {
          "name": "Listar jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/jobs?account_id={{account_id}}",
              "host": ["{{base_url}}"],
              "path": ["jobs"],
              "query": [
                { "key": "account_id", "value": "{{account_id}}" },
                { "key": "status", "value": "running", "disabled": true, "description": "pending | running | completed | failed | paused | cancelled" },
                { "key": "job_type", "value": "insights_campaigns", "disabled": true, "description": "insights_campaigns | insights_adsets | insights_ads | full_insights" },
                { "key": "limit", "value": "20", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Detalhe do job (polling)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/jobs/{{job_id}}",
              "host": ["{{base_url}}"],
              "path": ["jobs", "{{job_id}}"]
            },
            "description": "Endpoint principal para polling. Retorna progress_pct, cursor_date, records_synced e error_message se falhou."
          }
        },
        {
          "name": "Retomar job falho",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/jobs/{{job_id}}/resume",
              "host": ["{{base_url}}"],
              "path": ["jobs", "{{job_id}}", "resume"]
            },
            "description": "Retoma job em status 'failed' a partir do cursor_date. Zera retry_count e reinicia o worker."
          }
        },
        {
          "name": "Cancelar job",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/jobs/{{job_id}}/cancel",
              "host": ["{{base_url}}"],
              "path": ["jobs", "{{job_id}}", "cancel"]
            },
            "description": "Sinaliza cancelamento. O worker verifica a flag a cada chunk e para na próxima iteração."
          }
        }
      ]
    },
    {
      "name": "Campanhas — Leitura",
      "item": [
        {
