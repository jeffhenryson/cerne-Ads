              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.job_id) {",
                  "    pm.environment.set(\"job_id\", json.job_id);",
                  "    console.log(\"job_id salvo:\", json.job_id);",
                  "}"
